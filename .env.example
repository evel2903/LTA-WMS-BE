# Application
NODE_ENV=development
PORT=3000

# Database
DB_HOST=localhost
DB_PORT=3306
DB_USERNAME=root
DB_PASSWORD=your_password
DB_DATABASE=backend_seed

# JWT
JWT_SECRET=your_jwt_secret_key
JWT_EXPIRATION=1h

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60

# Upload
UPLOAD_DIR=uploads
UPLOAD_MAX_FILE_SIZE=5242880

# Redis
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=appseed:

# BullMQ
BULL_QUEUE_PREFIX=appseed

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=

# Seed
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_me
