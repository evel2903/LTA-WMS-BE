{
  "name": "be-nestjs-appseed",
  "version": "1.0.0",
  "private": true,
  "packageManager": "yarn@1.22.22",
  "description": "NestJS + PostgreSQL seed project with Clean Architecture",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node dist/Main.js",
    "dev": "nest start --watch",
    "dev:log": "node -e \"require('fs').mkdirSync('logs',{recursive:true})\" && nest start --watch 1> logs/dev.out.log 2> logs/dev.err.log",
    "start:dev": "nest start --watch",
    "build": "nest build && tsc-alias -p tsconfig.build.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "migration:generate": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:generate src/Shared/Database/Migrations/AutoMigration",
    "migration:run": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:revert",
    "seed:run": "ts-node src/Shared/Database/Seed/Seed.ts",
    "db:prepare": "yarn migration:run && yarn seed:run",
    "demo-data:reset": "ts-node src/Shared/Database/Seed/DemoDataCcReset.ts",
    "demo-data:seed": "ts-node src/Shared/Database/Seed/DemoDataCcSeed.ts",
    "demo-data:prepare": "yarn migration:run && yarn demo-data:reset && yarn seed:run && yarn demo-data:seed"
  },
  "dependencies": {
    "@nestjs/bullmq": "^11.0.4",
    "@nestjs/common": "^11.1.27",
    "@nestjs/config": "^4.0.4",
    "@nestjs/core": "^11.1.27",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.27",
    "@nestjs/swagger": "^11.4.4",
    "@nestjs/terminus": "^11.1.1",
    "@nestjs/throttler": "^6.5.0",
    "@nestjs/typeorm": "^11.0.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.1",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "cookie-parser": "^1.4.7",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "ioredis": "^5.11.1",
    "nodemailer": "^9.0.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.21.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^1.0.0"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.23",
    "@nestjs/schematics": "^11.1.0",
    "@nestjs/testing": "^11.1.27",
    "@types/cookie-parser": "^1.4.10",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/multer": "^2.1.0",
    "@types/node": "^25.9.3",
    "@types/nodemailer": "^8.0.1",
    "@types/pg": "^8.20.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-ui-express": "^4.1.6",
    "@typescript-eslint/eslint-plugin": "^8.61.1",
    "@typescript-eslint/parser": "^8.61.1",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}
