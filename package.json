{
  "name": "be-nestjs-appseed",
  "version": "1.0.0",
  "private": true,
  "description": "NestJS + MySQL seed project with Clean Architecture",
  "license": "UNLICENSED",
  "scripts": {
    "start": "node dist/Main.js",
    "dev": "nest start --watch",
    "dev:log": "node -e \"require('fs').mkdirSync('logs',{recursive:true})\" && nest start --watch 1> logs/dev.out.log 2> logs/dev.err.log",
    "start:dev": "nest start --watch",
    "build": "nest build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "lint": "eslint \"{src,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,test}/**/*.ts\" --fix",
    "format": "prettier --write \"{src,test}/**/*.ts\"",
    "format:check": "prettier --check \"{src,test}/**/*.ts\"",
    "migration:generate": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:generate src/Shared/Database/Migrations/AutoMigration",
    "migration:run": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d src/Shared/Database/TypeOrmDataSource.ts migration:revert",
    "seed:run": "ts-node src/Shared/Database/Seed/Seed.ts",
    "db:prepare": "npm run migration:run && npm run seed:run"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/bullmq": "^10.1.2",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/terminus": "^10.3.0",
    "@nestjs/throttler": "^6.4.0",
    "@nestjs/typeorm": "^10.0.2",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.58.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^16.4.7",
    "ioredis": "^5.6.1",
    "mysql2": "^3.14.0",
    "nodemailer": "^6.9.16",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "swagger-ui-express": "^5.0.1",
    "typeorm": "^0.3.25"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.9",
    "@nestjs/schematics": "^10.2.3",
    "@nestjs/testing": "^10.4.15",
    "@types/jest": "^29.5.14",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.12",
    "@types/node": "^20.17.6",
    "@types/nodemailer": "^6.4.17",
    "@types/swagger-ui-express": "^4.1.6",
    "@types/supertest": "^6.0.2",
    "jest": "^29.7.0",
    "supertest": "^7.0.0",
    "@typescript-eslint/eslint-plugin": "^8.18.2",
    "@typescript-eslint/parser": "^8.18.2",
    "eslint": "^9.17.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-prettier": "^5.2.1",
    "prettier": "^3.4.2",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3"
  }
}
